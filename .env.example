# Only uncomment if you happen to have a Google Workspace Account
# CREDENTIALS_FILE=<path>
# ROSADMIN_GOOGLE_SUBJECT=<DWD impersonation subject>

# Omit only if testing the real Google mirror
ROSADMIN_GOOGLE_DRY_RUN=1 
# Not strictly necessary
ROSADMIN_EXPECT_EXAMPLE_EMAILS=1 
# Optional - not needed (but still convenient) if using BOTONIO_SSO
ROSADMIN_FAKE_LOGIN=1

# See README for filling this values - this is OPTIONAL if you're enabling fake-login
# BOTONIO_SSO_PUBLIC_KEY=<twin to BOT_SSO_SIGNING_KEY>
# BOTONIO_SSO_BEARER=<same as BOT_SSO_CALLER_BEARER>
# BOTONIO_SSO_SOCKET_PATH=<same as BOT_SSO_SOCKET_PATH>
# BOTONIO_SSO_GUILD_ID=<same as DISCORD_GUILD_ID>
# BOTONIO_SSO_AUD=rosadmin
# BOTONIO_SSO_ISS=botonio
# BOTONIO_SSO_KID=v1

ROSADMIN_AUDIT_HMAC_KEY=<from the README serving section or `openssl rand -hex 32`>
ROSADMIN_DB_DSN="host=127.0.0.1 port=54432 dbname=rosadmin_dev user=rosadmin_app"

ROSADMIN_ADMIN_SOCKET=/tmp/rosadmin-admin.sock

SOLIDARITY_TECH_BASE_URL=http://127.0.0.1:8001
SOLIDARITY_TECH_MOCK=1
# Replace 123456789012345678 with your REAL DISCORD ID if you want to log in with actual SSO
SOLIDARITY_TECH_MOCK_PERSONAS=ralsei@example.com=leader:123456789012345678,kris@example.com=co_leader,susie@example.com=lapsed,noelle@example.com=good_standing

# The org-wide group every good-standing member belongs to
# ROSADMIN_MAIN_GROUP_EMAIL=members@example.net
# The domain every minted group address takes (e.g. portlanddsa.org)
# ROSADMIN_GROUP_EMAIL_DOMAIN=portlanddsa.org
# The org-wide main group's display name (its address is ROSADMIN_MAIN_GROUP_EMAIL)
# ROSADMIN_MAIN_GROUP_NAME=Portland DSA Members
# Armed-run cap on new groups per sweep (bootstrap ignores it); default 10
# ROSADMIN_MASS_CREATION_TRIPWIRE=10
# Google membership writes per second the sweep paces itself to; default 2.
# Courtesy pacing to stay within the Directory API's write quotas; only a bulk
# bootstrap run feels it. Raise it once a run shows headroom.
# ROSADMIN_GOOGLE_WRITE_RATE=2
# Share of the Solidarity Tech key's 60-per-30s request budget (default 55;
# lower it when another service shares the key)
# SOLIDARITY_TECH_REQUEST_BUDGET=40