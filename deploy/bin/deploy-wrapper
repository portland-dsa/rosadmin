#!/usr/bin/env bash
#
# deploy-wrapper - the ONLY command the rosadmin deploy keys may run.
#
# Installed at /opt/rosadmin/bin/deploy-wrapper (root-owned, mode 0755) and pinned as
# the forced command in each deploy user's authorized_keys and in sshd's ForceCommand.
# Three verbs - `upload <sha> <sha256>`, `activate <sha>`, `is-active` - and nothing
# else. The target ENVIRONMENT comes from the connecting user's identity, never an
# argument, so a staging key has no way to name production.
set -euo pipefail
set -f   # no globbing before we word-split $SSH_ORIGINAL_COMMAND

case "$(id -un)" in
  deploy-rosadmin-staging)    instance=staging ;;
  deploy-rosadmin-production) instance=production ;;
  *) echo "denied" >&2; exit 1 ;;
esac

root="/opt/rosadmin/$instance"
releases="$root/releases"
current="$root/current"
max_bytes=$((300 * 1024 * 1024))   # the venv tar (interpreter + wheels) is ~tens-100MB

set -- ${SSH_ORIGINAL_COMMAND:-}
action="${1:-}"

is_sha()    { [[ "${1:-}" =~ ^[0-9a-f]{40}$ ]]; }
is_sha256() { [[ "${1:-}" =~ ^[0-9a-f]{64}$ ]]; }

case "$action" in

  # upload <sha> <sha256> : stream the release tarball in on stdin, size-check it, and
  # verify its content digest (computed by CI) BEFORE it is stored - so a corrupt or
  # oversized stream can never become a runnable release.
  upload)
    sha="${2:-}";  is_sha "$sha"     || { echo "bad sha" >&2; exit 2; }
    want="${3:-}"; is_sha256 "$want" || { echo "bad digest" >&2; exit 2; }

    dest="$releases/$sha"
    install -d -m 0755 "$dest"
    tmp="$(mktemp "$dest/.upload.XXXXXX")"
    trap 'rm -f "$tmp"' EXIT
    cat > "$tmp"
    [ "$(stat -c %s "$tmp")" -le "$max_bytes" ] || { echo "upload too large" >&2; exit 2; }
    got="$(sha256sum "$tmp" | cut -d' ' -f1)"
    [ "$got" = "$want" ] || { echo "digest mismatch" >&2; exit 2; }
    mv -f "$tmp" "$dest/rosadmin.tar.gz"
    trap - EXIT
    echo "uploaded $sha to $instance"
    ;;

  # activate <sha> : extract the verified tarball under a jailed path, freeze it
  # read-only, point `current` at it, and restart.
  activate)
    sha="${2:-}"; is_sha "$sha" || { echo "bad sha" >&2; exit 2; }
    tar="$releases/$sha/rosadmin.tar.gz"
    [ -f "$tar" ] || { echo "no such release" >&2; exit 2; }
    tree="$releases/$sha/tree"

    # Jail extraction: refuse any member that is absolute or escapes via `..`, so a
    # verified-but-malicious tarball cannot write outside the release directory. The
    # sha256 gate proves the bytes; this proves the layout.
    if tar -tzf "$tar" | grep -Eq '(^/|(^|/)\.\.(/|$))'; then
      echo "unsafe tar member" >&2; exit 2
    fi
    # A prior activation of this sha froze its tree read-only below, which also
    # strips this user's power to unlink inside it - thaw before clearing so a
    # re-run of the same release is idempotent instead of thousands of rm errors.
    if [ -e "$tree" ]; then chmod -R u+w "$tree"; fi
    rm -rf "$tree"; install -d -m 0755 "$tree"
    tar -xzf "$tar" -C "$tree" --no-same-owner

    # Reject any extracted symlink whose target resolves OUTSIDE the release tree. The
    # name check above blocks absolute/.. member PATHS; this blocks a symlink whose TARGET
    # escapes. Internal links are allowed - the relocatable venv legitimately points
    # venv/bin/python3 at ../../python/bin/python3.13, which stays inside the tree.
    root_abs="$(realpath "$tree")"
    while IFS= read -r -d '' link; do
      target="$(realpath -m "$link")"
      case "$target/" in
        "$root_abs"/*) : ;;  # resolves inside the tree - allowed
        *) echo "symlink escapes release tree" >&2; rm -rf "$tree"; exit 2 ;;
      esac
    done < <(find "$tree" -type l -print0)

    # Freeze read-only. The service runs as a DIFFERENT, less-privileged user that gets
    # only read access, so the exposed service principal can never write its own code.
    # (The wrapper holds no chown privilege by design, so the tree stays deploy-user
    # owned rather than root-owned; the load-bearing boundary is the service user's lack
    # of write, not the owner.)
    chmod -R a-w "$tree"

    # Atomic symlink swap: build the new link beside the old one, then rename over it.
    ln -sfn "$tree/rosadmin" "$current.new"
    mv -Tf "$current.new" "$current"

    # Activation restarts the persistent web service (panel) - the single privileged
    # action; sudoers permits ONLY this exact line. Both stages run the same shape
    # now, so both restart identically; the base unit's ExecStartPre re-verifies the
    # freshly-linked tree against its manifest on start, and the sweep on its own
    # timer picks up the same swapped `current`.
    case "$instance" in
      staging | production)
        sudo /usr/bin/systemctl restart "rosadmin@$instance"
        ;;
    esac
    echo "activated $sha on $instance"
    ;;

  # is-active : report whether this environment's unit is up (needs no privilege).
  is-active)
    systemctl is-active "rosadmin@$instance" || true
    ;;

  *)
    echo "denied" >&2; exit 1
    ;;

esac
