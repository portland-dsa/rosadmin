rosadmin.staging.portlanddsa.org {
	# Same-origin CSP for the Vite SPA plus its API: connect-src 'self'
	# is already implied by default-src 'self', but the API surface
	# deserves to be visible in the policy. img-src/font-src allow `data:`
	# because Vite inlines small images/fonts that way; script-src stays at
	# the 'self' default (no 'unsafe-inline'/'unsafe-eval'). Still needs a
	# browser-validation pass against the served build before production -
	# watch the console for CSP violations.
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'"
		# Not load-bearing security, just noise reduction.
		-Server
	}

	# JSON access log to the default sink (stderr -> journald), for
	# CrowdSec's crowdsecurity/caddy collection to consume.
	log {
		format json
	}

	# trusted_proxies is deliberately not configured. Caddy
	# is the true edge (no CDN in front of it), so the connecting peer it
	# observes on the socket is the real client; a trusted_proxies entry
	# would instead make it trust a client-supplied X-Forwarded-For /
	# X-Real-IP, which would let an attacker forge an innocent IP into the
	# log and CrowdSec's ban list, or hide their own from both.

	# The API crosses to the backend over its unix socket. The socket's
	# 0660 group is what authorizes this hop - caddy is a member; no other
	# local user is. A 502 here means the backend socket is not up (yet).
	handle /api/* {
		reverse_proxy unix//run/rosadmin/staging/api.sock
	}

	# Everything else is the static frontend tree.
	handle {
		root * /opt/rosadmin-frontend/staging/current
		file_server
	}
}
