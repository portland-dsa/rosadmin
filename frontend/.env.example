# Set to "false" to talk to the real backend instead of the in-memory mock.
VITE_USE_MOCK=true

# Dev-only: when the backend runs with ROSADMIN_FAKE_LOGIN=1, sign in as a fake
# persona instead of Discord (the only auth path available off the Linux SSO
# host, e.g. local macOS dev). Ignored unless VITE_USE_MOCK=false.
VITE_FAKE_LOGIN=false

# Optional explicit backend origin. Leave empty to be same-origin as the app: the
# Vite dev server proxies /api to the backend (see vite.config.ts), and in
# production the SPA is served from the API's own origin.
VITE_API_BASE=
